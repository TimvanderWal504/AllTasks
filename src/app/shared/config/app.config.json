{
  "api": {
    "auth": {
      "registerUrl": "/api/auth/register",
      "loginUrl": "/api/auth/login",
      "requestPasswordResetUrl": "/api/auth/request-password-reset",
      "resetPasswordUrl": "/api/auth/reset-password"
    }
  },
  "storage": {
    "accessTokenKey": "accessToken",
    "refreshTokenKey": "refreshToken",
    "themeKey": "theme"
  },
  "database": {
    "name": "todo-pwa-db",
    "version": 1,
    "stores": {
      "tasks": "tasks"
    }
  },
  "serviceWorker": {
    "scriptUrl": "ngsw-worker.js",
    "registrationStrategy": "registerWhenStable:30000"
  },
  "sync": {
    "defaultTag": "sync-tasks"
  },
  "tasks": {
    "filter": {
      "defaultStatus": "all",
      "defaultSort": "createdAt",
      "queryParamStatus": "filter",
      "queryParamSort": "sort",
      "queryParamSearch": "search"
    }
  }
}
